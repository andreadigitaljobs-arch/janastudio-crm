# JanaStudio CRM - Variables de Entorno
# Copiar este archivo a .env y completar los valores

# Supabase Configuration
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Solo para scripts administrativos ejecutados desde una terminal segura.
# Nunca uses esta clave en variables VITE_* ni la expongas al navegador.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# App Configuration
VITE_APP_NAME=JanaStudio
VITE_APP_VERSION=1.0.0
